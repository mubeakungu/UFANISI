# Flask
SECRET_KEY=change-this-to-a-long-random-string
FLASK_ENV=development
DATABASE_URL=sqlite:///ufanisi_sacco.db

# Daraja / M-Pesa (get these from https://developer.safaricom.co.ke)
MPESA_ENV=sandbox
MPESA_CONSUMER_KEY=your_consumer_key
MPESA_CONSUMER_SECRET=your_consumer_secret
MPESA_SHORTCODE=174379
MPESA_PASSKEY=your_lipa_na_mpesa_passkey
MPESA_CALLBACK_URL=https://your-domain.example.com/mpesa/callback

# Sacco details
SACCO_NAME=Ufanisi Sacco

# Default admin bootstrap (only used the very first time the app runs, if no admin exists yet)
ADMIN_USERNAME=ADMIN
ADMIN_PASSWORD=Admin123
ADMIN_PHONE=0787187393

# Business rules
MIN_DEPOSIT_AMOUNT=5000

# Interest: "flat" = fixed KES amount per week per qualifying account.
# "percentage" = balance * rate per week instead (recommended for real use — see README).
INTEREST_MODE=flat
INTEREST_FLAT_AMOUNT=500
INTEREST_RATE=0.01
INTEREST_MIN_BALANCE=5000
INTEREST_WITHDRAWAL_COOLDOWN_DAYS=7

# Password reset email (optional). Leave blank to just log reset links to the console.
MAIL_SERVER=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_USE_TLS=true
MAIL_DEFAULT_SENDER=no-reply@ufanisisacco.example
APP_BASE_URL=http://localhost:5000
